body {
    font-family: Arial, sans-serif;
    margin: 0;
}

header {
    background-color: green;
    color: white;
    text-align: center;
    padding: 20px;
}

nav {
    margin-top: 10px;
}

a {
    color: white;
    text-decoration: none;
    margin: 10px;
}

main {
    padding: 20px;
}

h2 {
    color: green;
}
button {
    background-color: orange;
    color: white;
    border: none;
    padding: 15px 20px;
    border-radius: 20px;
    cursor: pointer;
    font-size: 16px;
}

footer {
    background-color: #ddd;
    text-align: center;
    padding: 10px;
}
input {
    padding: 15px;
    width: 500px;
    border-radius: 20px;
    border: 1px solid #ccc;
    font-size: 16px;
}

.mercados {
    display: flex;
    gap: 20px;
    margin-top: 15px;
}

.card {
    border: 2px solid green;
    border-radius: 10px;
    padding: 15px;
    width: 200px;
}
